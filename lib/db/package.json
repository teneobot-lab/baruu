{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.ts",
    "./schema": "./dist/schema/index.ts",
    "./schema/items": "./dist/schema/items.ts",
    "./schema/warehouses": "./dist/schema/warehouses.ts",
    "./schema/partners": "./dist/schema/partners.ts",
    "./schema/users": "./dist/schema/users.ts",
    "./schema/transactions": "./dist/schema/transactions.ts"
  },
  "scripts": {
